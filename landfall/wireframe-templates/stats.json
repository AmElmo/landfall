{
  "sectionType": "stats",
  "templates": [
    {
      "id": "stats-row",
      "name": "Row",
      "sectionType": "stats",
      "description": "Horizontal row of key statistics",
      "structure": "stats-row",
      "elements": [
        {
          "type": "card",
          "repeat": 4,
          "children": [
            { "type": "heading", "size": "large", "align": "center", "role": "stat-value" },
            { "type": "label", "size": "small", "align": "center", "role": "stat-label" }
          ]
        }
      ]
    },
    {
      "id": "stats-cards",
      "name": "Cards",
      "sectionType": "stats",
      "description": "Stats displayed in individual bordered cards",
      "structure": "stats-cards",
      "elements": [
        { "type": "heading", "size": "large", "align": "center", "role": "section-title" },
        {
          "type": "card",
          "repeat": 4,
          "children": [
            { "type": "heading", "size": "large", "align": "center", "role": "stat-value" },
            { "type": "label", "size": "small", "align": "center", "role": "stat-label" }
          ]
        }
      ]
    },
    {
      "id": "stats-with-icons",
      "name": "With Icons",
      "sectionType": "stats",
      "description": "Stats accompanied by relevant icons",
      "structure": "stats-icons",
      "elements": [
        { "type": "heading", "size": "large", "align": "center", "role": "section-title" },
        {
          "type": "card",
          "repeat": 4,
          "children": [
            { "type": "icon", "size": "medium", "role": "stat-icon" },
            { "type": "heading", "size": "large", "align": "center", "role": "stat-value" },
            { "type": "label", "size": "small", "align": "center", "role": "stat-label" }
          ]
        }
      ]
    },
    {
      "id": "stats-large-numbers",
      "name": "Large Numbers",
      "sectionType": "stats",
      "description": "Oversized numbers as the visual focus",
      "structure": "stats-large",
      "elements": [
        {
          "type": "card",
          "repeat": 3,
          "size": "large",
          "children": [
            { "type": "heading", "size": "large", "align": "center", "role": "stat-value" },
            { "type": "paragraph", "size": "medium", "align": "center", "role": "stat-description" }
          ]
        }
      ]
    }
  ]
}
