{
  "sectionType": "faq",
  "templates": [
    {
      "id": "faq-accordion",
      "name": "Accordion",
      "sectionType": "faq",
      "description": "Expandable accordion-style FAQ with click to reveal answers",
      "structure": "faq-accordion",
      "elements": [
        { "type": "heading", "size": "large", "align": "center", "role": "section-title" },
        { "type": "subheading", "size": "medium", "align": "center", "role": "section-subtitle" },
        {
          "type": "list",
          "repeat": 5,
          "children": [
            { "type": "heading", "size": "small", "role": "question" },
            { "type": "paragraph", "size": "medium", "role": "answer" }
          ]
        }
      ]
    },
    {
      "id": "faq-two-column",
      "name": "Two Column",
      "sectionType": "faq",
      "description": "Questions split into two columns for easier scanning",
      "structure": "faq-2-col",
      "elements": [
        { "type": "heading", "size": "large", "align": "center", "role": "section-title" },
        { "type": "subheading", "size": "medium", "align": "center", "role": "section-subtitle" },
        {
          "type": "card",
          "repeat": 6,
          "children": [
            { "type": "heading", "size": "small", "role": "question" },
            { "type": "paragraph", "size": "small", "role": "answer" }
          ]
        }
      ]
    },
    {
      "id": "faq-categorized",
      "name": "Categorized",
      "sectionType": "faq",
      "description": "FAQs grouped by category with section headers",
      "structure": "faq-categorized",
      "elements": [
        { "type": "heading", "size": "large", "align": "center", "role": "section-title" },
        {
          "type": "card",
          "repeat": 3,
          "children": [
            { "type": "heading", "size": "medium", "role": "category-name" },
            { "type": "list", "repeat": 3, "children": [
              { "type": "heading", "size": "small", "role": "question" },
              { "type": "paragraph", "size": "small", "role": "answer" }
            ]}
          ]
        }
      ]
    },
    {
      "id": "faq-simple-list",
      "name": "Simple List",
      "sectionType": "faq",
      "description": "Plain list of questions and answers, all visible",
      "structure": "faq-simple",
      "elements": [
        { "type": "heading", "size": "large", "align": "center", "role": "section-title" },
        {
          "type": "list",
          "repeat": 5,
          "children": [
            { "type": "heading", "size": "small", "role": "question" },
            { "type": "paragraph", "size": "medium", "role": "answer" }
          ]
        }
      ]
    }
  ]
}
