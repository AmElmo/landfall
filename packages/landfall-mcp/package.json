{
  "name": "landfall-mcp",
  "version": "0.1.0",
  "description": "MCP server for Landfall - orchestrate AI-powered landing page builds",
  "type": "module",
  "bin": {
    "landfall-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "mcp",
    "landfall",
    "ai",
    "landing-page",
    "claude",
    "cursor"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
