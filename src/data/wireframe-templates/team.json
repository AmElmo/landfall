{
  "sectionType": "team",
  "templates": [
    {
      "id": "team-grid",
      "name": "Grid",
      "sectionType": "team",
      "description": "Grid of team member cards with photos and titles",
      "structure": "team-grid",
      "elements": [
        { "type": "heading", "size": "large", "align": "center", "role": "section-title" },
        { "type": "subheading", "size": "medium", "align": "center", "role": "section-subtitle" },
        {
          "type": "card",
          "repeat": 4,
          "children": [
            { "type": "image", "size": "large", "role": "photo" },
            { "type": "heading", "size": "small", "role": "name" },
            { "type": "label", "size": "small", "role": "title" }
          ]
        }
      ]
    },
    {
      "id": "team-featured-leadership",
      "name": "Featured Leadership",
      "sectionType": "team",
      "description": "Larger cards for leadership with bios",
      "structure": "team-featured",
      "elements": [
        { "type": "heading", "size": "large", "align": "center", "role": "section-title" },
        { "type": "subheading", "size": "medium", "align": "center", "role": "section-subtitle" },
        {
          "type": "card",
          "repeat": 3,
          "size": "large",
          "children": [
            { "type": "image", "size": "large", "role": "photo" },
            { "type": "heading", "size": "medium", "role": "name" },
            { "type": "label", "size": "small", "role": "title" },
            { "type": "paragraph", "size": "small", "role": "bio" }
          ]
        }
      ]
    },
    {
      "id": "team-simple-list",
      "name": "Simple List",
      "sectionType": "team",
      "description": "Minimal list with names, roles, and small photos",
      "structure": "team-list",
      "elements": [
        { "type": "heading", "size": "large", "align": "center", "role": "section-title" },
        {
          "type": "list",
          "repeat": 6,
          "children": [
            { "type": "image", "size": "small", "role": "photo" },
            { "type": "heading", "size": "small", "role": "name" },
            { "type": "label", "size": "small", "role": "title" }
          ]
        }
      ]
    },
    {
      "id": "team-with-social",
      "name": "With Social Links",
      "sectionType": "team",
      "description": "Team cards with social media links",
      "structure": "team-social",
      "elements": [
        { "type": "heading", "size": "large", "align": "center", "role": "section-title" },
        { "type": "subheading", "size": "medium", "align": "center", "role": "section-subtitle" },
        {
          "type": "card",
          "repeat": 4,
          "children": [
            { "type": "image", "size": "large", "role": "photo" },
            { "type": "heading", "size": "small", "role": "name" },
            { "type": "label", "size": "small", "role": "title" },
            { "type": "icon", "size": "small", "role": "social-icon", "repeat": 3 }
          ]
        }
      ]
    }
  ]
}
