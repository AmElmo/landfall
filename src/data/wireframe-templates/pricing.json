{
  "sectionType": "pricing",
  "templates": [
    {
      "id": "pricing-three-tiers",
      "name": "Three Tiers",
      "sectionType": "pricing",
      "description": "Classic 3-column pricing with highlighted middle tier",
      "structure": "pricing-3-tiers",
      "elements": [
        { "type": "heading", "size": "large", "align": "center", "role": "section-title" },
        { "type": "subheading", "size": "medium", "align": "center", "role": "section-subtitle" },
        {
          "type": "card",
          "repeat": 3,
          "children": [
            { "type": "heading", "size": "small", "role": "plan-name" },
            { "type": "heading", "size": "large", "role": "price" },
            { "type": "label", "size": "small", "role": "billing-period" },
            { "type": "list", "repeat": 4, "children": [{ "type": "paragraph", "size": "small", "role": "feature" }] },
            { "type": "button-primary", "size": "medium", "role": "cta" }
          ]
        }
      ]
    },
    {
      "id": "pricing-two-tiers",
      "name": "Two Tiers",
      "sectionType": "pricing",
      "description": "Simple 2-plan comparison side by side",
      "structure": "pricing-2-tiers",
      "elements": [
        { "type": "heading", "size": "large", "align": "center", "role": "section-title" },
        { "type": "subheading", "size": "medium", "align": "center", "role": "section-subtitle" },
        {
          "type": "card",
          "repeat": 2,
          "size": "large",
          "children": [
            { "type": "heading", "size": "medium", "role": "plan-name" },
            { "type": "heading", "size": "large", "role": "price" },
            { "type": "label", "size": "small", "role": "billing-period" },
            { "type": "paragraph", "size": "medium", "role": "plan-description" },
            { "type": "list", "repeat": 5, "children": [{ "type": "paragraph", "size": "small", "role": "feature" }] },
            { "type": "button-primary", "size": "large", "role": "cta" }
          ]
        }
      ]
    },
    {
      "id": "pricing-comparison",
      "name": "Comparison Table",
      "sectionType": "pricing",
      "description": "Detailed feature comparison matrix across plans",
      "structure": "pricing-comparison",
      "elements": [
        { "type": "heading", "size": "large", "align": "center", "role": "section-title" },
        { "type": "subheading", "size": "medium", "align": "center", "role": "section-subtitle" },
        {
          "type": "card",
          "size": "large",
          "children": [
            { "type": "heading", "size": "small", "role": "plan-name", "repeat": 3 },
            { "type": "heading", "size": "medium", "role": "price", "repeat": 3 },
            { "type": "list", "repeat": 6, "children": [
              { "type": "paragraph", "size": "small", "role": "feature-name" },
              { "type": "icon", "size": "small", "role": "feature-check" }
            ]}
          ]
        }
      ]
    },
    {
      "id": "pricing-toggle",
      "name": "With Toggle",
      "sectionType": "pricing",
      "description": "Monthly/annual toggle with pricing cards",
      "structure": "pricing-toggle",
      "elements": [
        { "type": "heading", "size": "large", "align": "center", "role": "section-title" },
        { "type": "subheading", "size": "medium", "align": "center", "role": "section-subtitle" },
        { "type": "button-secondary", "size": "small", "role": "billing-toggle" },
        {
          "type": "card",
          "repeat": 3,
          "children": [
            { "type": "heading", "size": "small", "role": "plan-name" },
            { "type": "heading", "size": "large", "role": "price" },
            { "type": "list", "repeat": 4, "children": [{ "type": "paragraph", "size": "small", "role": "feature" }] },
            { "type": "button-primary", "size": "medium", "role": "cta" }
          ]
        }
      ]
    },
    {
      "id": "pricing-single",
      "name": "Single Plan",
      "sectionType": "pricing",
      "description": "One featured plan with detailed feature list",
      "structure": "pricing-single",
      "elements": [
        { "type": "heading", "size": "large", "align": "center", "role": "section-title" },
        { "type": "subheading", "size": "medium", "align": "center", "role": "section-subtitle" },
        {
          "type": "card",
          "size": "large",
          "children": [
            { "type": "heading", "size": "large", "role": "price" },
            { "type": "paragraph", "size": "medium", "role": "plan-description" },
            { "type": "list", "repeat": 6, "children": [
              { "type": "icon", "size": "small", "role": "check-icon" },
              { "type": "paragraph", "size": "medium", "role": "feature" }
            ]},
            { "type": "button-primary", "size": "large", "role": "cta" }
          ]
        }
      ]
    }
  ]
}
